    {
      "parameters": {
        "schemaType": "manual",
        "inputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"blog_draft\": { \"type\": \"string\" },\n    \"linkedin_caption\": { \"type\": \"string\" },\n    \"instagram_caption\": { \"type\": \"string\" },\n    \"twitter_caption\": { \"type\": \"string\" },\n    \"newsletter_draft\": { \"type\": \"string\" },\n    \"visual_prompt\": { \"type\": \"string\" }\n  },\n  \"required\": [\n    \"blog_draft\",\n    \"linkedin_caption\",\n    \"instagram_caption\",\n    \"twitter_caption\",\n    \"newsletter_draft\",\n    \"visual_prompt\"\n  ]\n}"
      },
      "id": "bcf53ce4-9242-4f39-944f-25a16dc9759c",
      "name": "Parse Content Output",
      "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
