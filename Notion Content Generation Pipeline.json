    {
      "parameters": {
        "jsCode": "const brief = $('Prepare Brief Data').first().json;\nconst out = $json.output || $json || {};\n\nfunction asText(v) {\n  if (v === null || v === undefined) return \"\";\n  if (typeof v === \"string\") return v;\n  if (typeof v === \"number\") return String(v);\n  if (typeof v === \"boolean\") return v ? \"true\" : \"false\";\n  if (Array.isArray(v)) return v.map(asText).filter(Boolean).join(\", \");\n  if (typeof v === \"object\") return JSON.stringify(v);\n  return \"\";\n}\n\nconst briefIdText = asText(brief.brief_id).trim();\nconst briefIdNumber = briefIdText && !isNaN(Number(briefIdText)) ? Number(briefIdText) : 0;\n\nreturn [{\n  json: {\n    notion_page_id: asText(brief.notion_page_id),\n    source_brief_id: briefIdText,\n    content_id: briefIdNumber,\n    content_name: `Generated Content ${briefIdText || \"Untitled\"}`,\n    brief_name: asText(brief.name),\n    campaign_name: asText(brief.campaign_name),\n    week: asText(brief.week),\n    audience: asText(brief.audience),\n    goal: asText(brief.goal),\n    offer_cta: asText(brief.offer_cta),\n    tone: asText(brief.tone),\n    keywords: asText(brief.keywords),\n    blog_topic: asText(brief.blog_topic),\n    social_platforms: asText(brief.social_platforms),\n    raw_brief: asText(brief.raw_brief),\n    blog_draft: asText(out.blog_draft),\n    linkedin_caption: asText(out.linkedin_caption),\n    instagram_caption: asText(out.instagram_caption),\n    twitter_caption: asText(out.twitter_caption),\n    newsletter_draft: asText(out.newsletter_draft),\n    visual_prompt: asText(out.visual_prompt)\n  }\n}];"
      },
