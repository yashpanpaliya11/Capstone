    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst p = item.properties || item;\n\nfunction getText(v) {\n  if (!v) return \"\";\n  if (typeof v === \"string\") return v;\n  if (typeof v === \"number\") return String(v);\n\n  if (v.title) return v.title.map(x => x.plain_text || \"\").join(\"\");\n  if (v.rich_text) return v.rich_text.map(x => x.plain_text || \"\").join(\"\");\n  if (v.select) return v.select.name || \"\";\n  if (v.number !== undefined && v.number !== null) return String(v.number);\n\n  if (Array.isArray(v)) {\n    return v.map(x => {\n      if (typeof x === \"string\") return x;\n      if (x?.name) return x.name;\n      if (x?.plain_text) return x.plain_text;\n      return \"\";\n    }).filter(Boolean).join(\", \");\n  }\n\n  if (v.multi_select && Array.isArray(v.multi_select)) {\n    return v.multi_select.map(x => x.name || \"\").filter(Boolean).join(\", \");\n  }\n\n  return \"\";\n}\n\nreturn [{\n  json: {\n    notion_page_id: item.id || \"\",\n    brief_id: getText(p[\"Brief ID\"]),\n    name: getText(p[\"Name\"]),\n    week: getText(p[\"Week\"]),\n    campaign_name: getText(p[\"Campaign Name\"]),\n    audience: getText(p[\"Audience\"]),\n    goal: getText(p[\"Goal\"]),\n    offer_cta: getText(p[\"Offer / CTA\"]),\n    tone: getText(p[\"Tone\"]),\n    keywords: getText(p[\"Keywords\"]),\n    blog_topic: getText(p[\"Blog Topic\"]),\n    social_platforms: getText(p[\"Social Platforms\"]),\n    raw_brief: getText(p[\"Raw Brief\"]),\n    content_status: getText(p[\"Content Status\"])\n  }\n}];"
      },
      "id": "f4c5f3d1-4853-4a1e-b263-901c326aa375",
      "name": "Prepare Brief Data",
